@inherits LayoutComponentBase
@inject ExplorerStateService StateService

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <button class="btn btn-premium-primary btn-sm" @onclick="StateService.OpenCreateModal">
                <i class="bi bi-plus-lg"></i> Add New Prompt
            </button>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
