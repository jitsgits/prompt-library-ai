@page "/"
@page "/prompt/{PromptId}"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Prompt Library Dashboard</PageTitle>

<div class="container-fluid py-4">

    @if (StateService.IsLoading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center my-5 py-5">
            <div class="spinner-border text-primary" role="status" style="border-color: var(--accent-purple) transparent var(--accent-purple) transparent;">
                <span class="visually-hidden">Loading prompts...</span>
            </div>
            <p class="text-secondary mt-3">Connecting to Prompt Service...</p>
        </div>
    }
    else if (StateService.ErrorMessage != null)
    {
        <div class="glass-card text-center my-5 p-5 border-danger">
            <h4 class="text-danger">Unable to load prompts</h4>
            <p class="text-secondary my-3">@StateService.ErrorMessage</p>
            <button class="btn btn-premium-secondary" @onclick="LoadPrompts">Retry Connection</button>
        </div>
    }
    else
    {
        @if (StateService.SelectedPrompt != null)
        {
            <!-- Selected Prompt Detail View -->
            <div class="prompt-detail-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <button class="btn btn-premium-secondary btn-sm" @onclick="DeselectPrompt">
                        <i class="bi bi-arrow-left"></i> Back to Grid
                    </button>
                    <span class="category-badge @GetCategoryClass(StateService.SelectedPrompt.Category)">@StateService.SelectedPrompt.Category</span>
                </div>

                <h2 class="h3 mb-2">@StateService.SelectedPrompt.Title</h2>
                <div class="text-muted small mb-3">
                    <i class="bi bi-calendar-event"></i> Created: @StateService.SelectedPrompt.CreatedOn.ToLocalTime().ToString("MMMM dd, yyyy")
                </div>

                <p class="text-secondary mb-4 fs-5">@StateService.SelectedPrompt.Description</p>

                <div class="mb-4">
                    <h4 class="h6 text-secondary text-uppercase mb-2">Prompt Template</h4>
                    <div class="position-relative">
                        <pre class="prompt-detail-pre">@StateService.SelectedPrompt.PromptText</pre>
                        <button class="copy-btn position-absolute top-0 end-0 m-3 @(copiedPromptId == StateService.SelectedPrompt.Id ? "copied" : "")" 
                                @onclick="() => CopyToClipboard(StateService.SelectedPrompt)">
                            @if (copiedPromptId == StateService.SelectedPrompt.Id)
                            {
                                <i class="bi bi-check-lg"></i> <span>Copied!</span>
                            }
                            else
                            {
                                <i class="bi bi-clipboard"></i> <span>Copy Prompt</span>
                            }
                        </button>
                    </div>
                </div>

                <div class="mb-2">
                    <h4 class="h6 text-secondary text-uppercase mb-2">Tags</h4>
                    @foreach (var tag in StateService.SelectedPrompt.Tags)
                    {
                        <span class="tag-pill cursor-pointer" style="cursor: pointer;" @onclick="() => ToggleTag(tag)">#@tag</span>
                    }
                </div>
            </div>
        }
        else
        {
            <!-- Search bar and details summary header -->
            <div class="row mb-4 align-items-center">
                <div class="col-lg-6 mb-3 mb-lg-0">
                    <div class="position-relative">
                        <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                        <input type="text" 
                               class="form-control premium-search" 
                               style="padding-left: 2.75rem !important; border-radius: 12px !important;"
                               placeholder="Search by title, tags or content..." 
                               @bind="StateService.SearchQuery" 
                               @bind:event="oninput"
                               @bind:after="StateService.NotifyStateChanged" />
                    </div>
                </div>
                <div class="col-lg-6 text-lg-end">
                    <span class="text-secondary small">
                        Showing <b>@StateService.FilteredPrompts.Count()</b> of <b>@StateService.Prompts.Count</b> prompts
                    </span>
                </div>
            </div>

            <!-- Prompt Cards Grid (Full Width layout) -->
            <div class="row g-4">
                @foreach (var prompt in StateService.FilteredPrompts)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="glass-card h-100 d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <span class="category-badge @GetCategoryClass(prompt.Category)">@prompt.Category</span>
                                    <small class="text-muted">@prompt.CreatedOn.ToLocalTime().ToString("MMM dd, yyyy")</small>
                                </div>
                                <h3 class="h5 mb-2" style="cursor: pointer; transition: color 0.2s;" @onclick="() => SelectPrompt(prompt)">
                                    @prompt.Title
                                </h3>
                                <p class="text-secondary small mb-3">@prompt.Description</p>
                                
                                <div class="prompt-text-display mb-3" style="cursor: pointer;" @onclick="() => SelectPrompt(prompt)">
                                    @prompt.PromptText
                                </div>
                            </div>

                            <div>
                                <div class="mb-3">
                                    @foreach (var tag in prompt.Tags)
                                    {
                                        <span class="tag-pill cursor-pointer" style="cursor: pointer;" @onclick="() => ToggleTag(tag)">#@tag</span>
                                    }
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <button class="btn btn-link btn-sm p-0 text-decoration-none text-purple small" @onclick="() => SelectPrompt(prompt)">
                                        Explore <i class="bi bi-chevron-right"></i>
                                    </button>
                                    <button class="copy-btn @(copiedPromptId == prompt.Id ? "copied" : "")" @onclick="() => CopyToClipboard(prompt)" @onclick:stopPropagation="true">
                                        @if (copiedPromptId == prompt.Id)
                                        {
                                            <i class="bi bi-check-lg"></i> <span>Copied!</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-clipboard"></i> <span>Copy</span>
                                        }
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (!StateService.FilteredPrompts.Any())
                {
                    <div class="col-12 text-center py-5">
                        <p class="text-secondary fs-5">No prompts matched your search filters.</p>
                    </div>
                }
            </div>
        }
    }
</div>

<!-- Create Prompt Modal -->
<div class="modal-overlay @(StateService.ShowCreateModal ? "show" : "")">
    @if (StateService.ShowCreateModal)
    {
        <AddPromptForm OnPromptSaved="OnPromptSaved" OnCancel="StateService.CloseCreateModal" />
    }
</div>

@code {
    [Inject] public ExplorerStateService StateService { get; set; } = default!;

    [Parameter]
    public string? PromptId { get; set; }

    private string? copiedPromptId;

    protected override async Task OnInitializedAsync()
    {
        StateService.OnStateChanged += StateHasChanged;
        
        if (!StateService.Prompts.Any())
        {
            await LoadPrompts();
        }

        ApplyPromptParameterSelection();
    }

    protected override void OnParametersSet()
    {
        ApplyPromptParameterSelection();
    }

    private void ApplyPromptParameterSelection()
    {
        if (!string.IsNullOrEmpty(PromptId) && StateService.Prompts.Any())
        {
            var prompt = StateService.Prompts.FirstOrDefault(p => p.Id == PromptId);
            if (prompt != null)
            {
                if (StateService.SelectedPrompt?.Id != prompt.Id)
                {
                    StateService.SelectPrompt(prompt);
                }
            }
        }
        else if (string.IsNullOrEmpty(PromptId))
        {
            if (StateService.SelectedPrompt != null)
            {
                StateService.DeselectPrompt();
            }
        }
    }

    public void Dispose()
    {
        StateService.OnStateChanged -= StateHasChanged;
    }

    private async Task LoadPrompts()
    {
        await StateService.LoadPrompts();
    }

    private void DeselectPrompt()
    {
        Navigation.NavigateTo("/");
    }
    
    private void SelectPrompt(Prompt prompt)
    {
        Navigation.NavigateTo($"/prompt/{prompt.Id}");
    }
    
    private void ToggleTag(string tag) => StateService.ToggleTag(tag);

    private string GetCategoryClass(string category) => category.ToLowerInvariant() switch
    {
        "coding" => "category-coding",
        "creative" => "category-creative",
        "analysis" => "category-analysis",
        "marketing" => "category-marketing",
        _ => "bg-secondary"
    };

    private async Task CopyToClipboard(Prompt prompt)
    {
        copiedPromptId = prompt.Id;
        await JS.InvokeVoidAsync("clipboardCopy.copyText", prompt.PromptText);
        
        // Reset copied indicator after 2 seconds
        _ = Task.Run(async () =>
        {
            await Task.Delay(2000);
            copiedPromptId = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private void OnPromptSaved(Prompt created)
    {
        StateService.Prompts.Add(created);
        StateService.ExpandedCategories.Add(created.Category);
        StateService.CloseCreateModal();
        Navigation.NavigateTo($"/prompt/{created.Id}");
    }
}
