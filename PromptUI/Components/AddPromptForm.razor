@using System.ComponentModel.DataAnnotations
@using PromptUI.Models
@using PromptUI.Services
@inject HttpClient Http
@inject ExplorerStateService StateService

<div class="glass-card modal-content-glass modal-content-glass-fullscreen m-3">
    <h3 class="mb-4 text-center">Add New Prompt</h3>
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger small mb-3">@errorMessage</div>
    }

    <EditForm Model="@newPromptModel" OnValidSubmit="HandleSubmit" style="height: calc(100% - 3.5rem); display: flex; flex-direction: column;">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger small mb-3" />

        <div class="form-grow-section">
            <div class="mb-3">
                <label class="form-label text-secondary small">Title</label>
                <InputText class="form-control premium-input" @bind-Value="newPromptModel.Title" placeholder="e.g. Git Commit Message Assistant" />
            </div>

            <div class="mb-3">
                <label class="form-label text-secondary small">Description</label>
                <InputText class="form-control premium-input" @bind-Value="newPromptModel.Description" placeholder="e.g. Helps write standardized, crisp commit logs." />
            </div>

            <div class="mb-3 textarea-grow-wrapper">
                <label class="form-label text-secondary small">Prompt Instructions</label>
                <InputTextArea class="form-control premium-textarea" @bind-Value="newPromptModel.PromptText" placeholder="Write the system prompt instructions here..." />
            </div>

            <div class="row">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label class="form-label text-secondary small">Category</label>
                    <InputSelect class="form-select premium-select" @bind-Value="selectedCategory">
                        @foreach (var cat in availableCategories)
                        {
                            <option value="@cat">@cat</option>
                        }
                        <option value="__new__">+ New category...</option>
                    </InputSelect>
                    @if (selectedCategory == "__new__")
                    {
                        <input type="text" class="form-control premium-input mt-2"
                               @bind="customCategory"
                               placeholder="Enter new category name" />
                    }
                </div>
                <div class="col-sm-6 mb-3">
                    <label class="form-label text-secondary small">Tags (comma separated)</label>
                    <InputText class="form-control premium-input" @bind-Value="tagsInput" placeholder="git, devops, productivity" />
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-auto pt-3 border-top" style="border-color: var(--border-color) !important;">
            <button type="button" class="btn btn-premium-secondary" @onclick="Cancel">Cancel</button>
            <button type="submit" class="btn btn-premium-primary" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <span>Save Prompt</span>
                }
            </button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public EventCallback<Prompt> OnPromptSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private PromptModel newPromptModel = new();
    private string tagsInput = "";
    private bool isSubmitting = false;
    private string? errorMessage;
    private string selectedCategory = "";
    private string customCategory = "";
    private List<string> availableCategories = new();

    protected override void OnInitialized()
    {
        availableCategories = StateService.Categories.ToList();
        if (!availableCategories.Any())
        {
            availableCategories = new List<string> { "Coding", "Analysis", "Creative", "Marketing" };
        }
        selectedCategory = availableCategories.First();
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        var parsedTags = string.IsNullOrWhiteSpace(tagsInput)
            ? Array.Empty<string>()
            : tagsInput.Split(',', StringSplitOptions.RemoveEmptyEntries)
                       .Select(t => t.Trim().ToLowerInvariant())
                       .ToArray();

        var resolvedCategory = selectedCategory == "__new__"
            ? (string.IsNullOrWhiteSpace(customCategory) ? "General" : customCategory.Trim())
            : selectedCategory;

        var payload = new Prompt(
            "",
            newPromptModel.Title ?? "",
            newPromptModel.Description ?? "",
            newPromptModel.PromptText ?? "",
            resolvedCategory,
            parsedTags,
            DateTime.UtcNow
        );

        try
        {
            var response = await Http.PostAsJsonAsync("api/prompts", payload);
            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<Prompt>();
                if (created != null)
                {
                    await OnPromptSaved.InvokeAsync(created);
                }
            }
            else
            {
                var details = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to create prompt: {details}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error posting new prompt: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class PromptModel
    {
        [Required]
        [StringLength(100, MinimumLength = 3)]
        public string? Title { get; set; }

        [Required]
        [StringLength(200, MinimumLength = 5)]
        public string? Description { get; set; }

        [Required]
        [StringLength(2000, MinimumLength = 10)]
        public string? PromptText { get; set; }

        [Required]
        public string? Category { get; set; }
    }
}
